{
  "name": "authier-web-extension",
  "displayName": "Authier",
  "version": "1.2.4",
  "description": "Authier web Extension for all our supported browsers",
  "license": "AGPL-3.0-or-later",
  "webExt": {
    "sourceDir": "dist/"
  },
  "scripts": {
    "prodBuild": "NODE_ENV=production webpack --config webpack.prod.js",
    "devBuild": "webpack --config webpack.dev.js",
    "release": "npm version patch && git add package.json && npx tsx ./scripts/generateExtensionManifest.ts && npx tsx ./scripts/release.ts",
    "releaseMinor": "npm version minor && git add package.json && npx tsx ./scripts/generateExtensionManifest.ts && npx tsx ./scripts/release.ts",
    "generateManifest": "npx tsx ./scripts/generateExtensionManifest.ts",
    "clean": "rm -rf dist/js",
    "checkBuildOutput": "node ./check-es6.js",
    "dev": "NODE_ENV=development webpack -w --config webpack.dev.js",
    "tsc": "tsc",
    "lingui": "lingui extract && lingui compile",
    "lingui:extract": "lingui extract",
    "lingui:compile": "lingui compile",
    "test": "node ./scripts/ensureWorkspaceNodeModules.mjs && vitest run",
    "test:watch": "node ./scripts/ensureWorkspaceNodeModules.mjs && vitest",
    "w": "node ./scripts/ensureWorkspaceNodeModules.mjs && vitest",
    "test:coverage": "node ./scripts/ensureWorkspaceNodeModules.mjs && vitest run --coverage",
    "test:ui": "node ./scripts/ensureWorkspaceNodeModules.mjs && vitest --ui",
    "playwright:run": "npx playwright test",
    "gen": "cd .. && graphql-codegen",
    "test:run": "cd .. && cd backend && pnpm gen && pnpm dev",
    "uploadApp": "dotenv chrome-webstore-upload upload --source dist.zip --extension-id $EXTENSION_ID --client-id $CLIENT_ID --client-secret $CLIENT_SECRET --refresh-token $REFRESH_TOKEN",
    "publishApp:chrome": "dotenv chrome-webstore-upload publish --source dist.zip --extension-id padmmdghcflnaellmmckicifafoenfdi",
    "publishApp:firefox": "bash -c 'source .env && pnpm exec web-ext sign --source-dir=./dist --api-key=\"$FIREFOX_API_KEY\" --api-secret=\"$FIREFOX_API_SECRET\" --channel=listed'",
    "release:firefox": "pnpm clean && pnpm generateManifest && pnpm prodBuild && pnpm publishApp:firefox"
  },
  "keywords": [
    "react",
    "typescript",
    "chrome",
    "extension",
    "boilerplate"
  ],
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@lingui/react": "^5.9.5",
    "@lingui/vite-plugin": "^5.9.5",
    "@playwright/test": "^1.59.1",
    "@svgr/webpack": "^8.1.0",
    "@types/chrome": "^0.1.39",
    "@types/crypto-js": "^4.2.2",
    "@types/debug": "^4.1.13",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-test-renderer": "^19",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.3",
    "@vitest/ui": "^4.1.3",
    "acorn": "^8.16.0",
    "ajv": "^8.18.0",
    "babel-core": "^6.26.3",
    "babel-loader": "^10.1.1",
    "babel-plugin-import-graphql": "^2.8.1",
    "chrome-webstore-upload-cli": "^3.5.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "date-fns": "^4.1.0",
    "debug": "^4.4.3",
    "dotenv-cli": "^11.0.0",
    "dotenv-webpack": "^9.0.0",
    "esbuild-loader": "^4.4.3",
    "firebase": "12.11.0",
    "html-webpack-plugin": "^5.6.6",
    "js-file-download": "^0.4.12",
    "jsdom": "^29.0.2",
    "lodash": "^4.18.1",
    "mem": "^10",
    "mitt": "^3.0.1",
    "mockzilla": "^0.14.0",
    "mockzilla-webextension": "^0.15.0",
    "ms": "^2.1.3",
    "papaparse": "^5.5.3",
    "pretty-quick": "^4.2.2",
    "process": "^0.11.10",
    "proxy-date": "^0.9.1",
    "react-dropzone": "^15.0.0",
    "sass-loader": "^16.0.7",
    "slugify": "^1.6.9",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.4.0",
    "tsx": "^4.21.0",
    "type-graphql": "^1.1.1",
    "typescript": "^6.0.2",
    "vitest": "4.1.3",
    "vm-browserify": "^1.1.2",
