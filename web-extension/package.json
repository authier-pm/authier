    "react-grab": "^0.1.31",
    "react-hook-form": "^7.72.1",
    "react-icons": "^5.6.0",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "7.6.2",
    "react-select": "^5.10.2",
    "react-test-renderer": "^19.2.4",
    "react-transition-group": "^4.4.5",
    "react-virtual": "^2.10.4",
    "react-virtualized": "^9.22.6",
    "react-window": "^2.2.7",
