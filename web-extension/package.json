    "@ts-react/form": "^1.8.3",
    "@types/offscreencanvas": "^2019.7.3",
    "apollo3-cache-persist": "^0.15.0",
    "babel-plugin-macros": "^3.1.0",
    "base64-arraybuffer": "^1.0.2",
    "bowser": "^2.14.1",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crypto-browserify": "^3.12.1",
