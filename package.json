{
  "name": "authier",
  "private": true,
  "version": "1.0.0",
  "main": "index.js",
  "repository": "https://github.com/capaj/authier.git",
  "authors": [
    "Petr <petrik.spac@gmail.com>",
    "Jiri Spac <capajj@gmail.com>"
  ],
  "license": "AGPL-3.0-or-later",
  "overrides": {
    "graphql": "^16.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@apollo/client": "^4.1.5",
    "@chakra-ui/react": "2.10.4",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@graphql-codegen/cli": "^6.1.2",
    "@graphql-codegen/fragment-matcher": "^6.0.0",
    "@graphql-codegen/introspection": "^5.0.0",
    "@graphql-codegen/near-operation-file-preset": "^4.0.0",
    "@graphql-codegen/typescript": "^5.0.8",
    "@graphql-codegen/typescript-operations": "^5.0.8",
    "@graphql-codegen/typescript-react-apollo": "^4.4.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "concurrently": "^9.2.1",
    "framer-motion": "^12",
    "generate-password": "^1.7.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "zod": "^4.3.6",
    "zx": "^8.8.5"
  },
  "scripts": {
    "dev:be": "cd backend && pnpm run dev",
    "dev:ex": "cd web-extension && pnpm run dev",
    "dev": "concurrently \"pnpm dev:be\" \"pnpm dev:ex\"",
    "tsc": "cd backend && tsc && cd .. && cd web-extension && tsc && cd .. && cd mobile-app && tsc",
    "bump": "npm-run-all --parallel bump:*",
    "bump:be": "cd backend && ncu -u",
    "bump:ex": "cd web-extension && ncu -u",
    "bump:w": "ncu -u",
    "test": "cd backend && pnpm test && cd .. && cd web-extension && pnpm test",
    "gfs": "graphql-codegen --config codegen.yml",
    "gbs": "cd backend && pnpm gbs",
    "schemas": "pnpm gbs && pnpm gfs",
    "preinstall": "npx only-allow pnpm",
    "release": "cd web-extension && pnpm run release"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@capaj/type-graphql",
      "@prisma/engines",
      "@swc/core",
      "esbuild",
      "prisma",
      "type-graphql"
    ],
    "overrides": {
      "ajv": "^8.18.0",
      "react": "^19.2.4",
      "react-dom": "^19.2.4"
    },
    "patchedDependencies": {
      "@graphql-codegen/visitor-plugin-common@6.2.3": "patches/@graphql-codegen__visitor-plugin-common@6.2.3.patch",
      "@graphql-codegen/cli@6.1.2": "patches/@graphql-codegen__cli@6.1.2.patch",
      "@graphql-codegen/typescript-react-apollo@4.4.0": "patches/@graphql-codegen__typescript-react-apollo@4.4.0.patch",
      "@react-native/gradle-plugin": "patches/@react-native__gradle-plugin.patch",
      "native-base@3.4.28": "patches/native-base@3.4.28.patch"
    }
  }
}
