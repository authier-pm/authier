{
  "name": "authier",
  "private": true,
  "version": "1.0.0",
  "main": "index.js",
  "repository": "https://github.com/capaj/authier.git",
  "authors": [
    "Petr <petrik.spac@gmail.com>",
    "Jiri Spac <capajj@gmail.com>"
  ],
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@10.26.2",
  "overrides": {
    "graphql": "^16.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "@types/react": "^19",
    "@types/react-dom": "^19"
  },
  "devDependencies": {
    "@apollo/client": "^4.1.6",
    "@chakra-ui/react": "2.10.4",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/fragment-matcher": "^6.0.0",
    "@graphql-codegen/introspection": "^5.0.1",
    "@graphql-codegen/near-operation-file-preset": "^5.0.0",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@graphql-codegen/typescript-react-apollo": "^4.4.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "framer-motion": "^12",
    "generate-password": "^1.7.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript": "^6.0.2",
    "vite-tsconfig-paths": "^6.1.1",
    "zod": "^4.3.6",
    "zx": "^8.8.5"
  },
  "scripts": {
    "dev:be": "cd backend && pnpm run dev",
    "dev:be:local": "cd backend && pnpm run local",
    "dev:ex": "cd web-extension && pnpm run dev",
    "dev:vault-fe": "cd vault-web && pnpm run dev",
    "dev:vault": "turbo run local --filter=authier-backend --filter=authier-vault-web",
    "dev": "turbo run dev --filter=authier-backend --filter=authier-web-extension",
    "tsc": "turbo run tsc",
    "bump": "npm-run-all --parallel bump:*",
    "bump:be": "cd backend && ncu -u",
    "bump:ex": "cd web-extension && ncu -u",
    "bump:w": "ncu -u",
    "test": "cd backend && pnpm test && cd .. && cd web-extension && pnpm test && cd .. && cd vault-web && pnpm test",
    "gfs": "graphql-codegen --config codegen.yml",
    "gbs": "cd backend && pnpm gbs",
    "schemas": "pnpm gbs && pnpm gfs",
    "preinstall": "npx only-allow pnpm",
    "release": "cd web-extension && pnpm run release"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@capaj/type-graphql",
      "@prisma/engines",
      "@swc/core",
      "esbuild",
      "prisma",
      "type-graphql"
    ],
    "overrides": {
      "ajv": "^8.18.0",
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "@types/react": "^19",
      "@types/react-dom": "^19"
    },
    "patchedDependencies": {
      "@react-native/gradle-plugin": "patches/@react-native__gradle-plugin.patch",
      "native-base@3.4.28": "patches/native-base@3.4.28.patch",
      "@graphql-codegen/typescript-react-apollo": "patches/@graphql-codegen__typescript-react-apollo.patch"
    }
  }
}
