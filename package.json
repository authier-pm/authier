{
  "name": "authier",
  "private": true,
  "version": "1.0.0",
  "main": "index.js",
  "repository": "https://github.com/capaj/authier.git",
  "authors": [
    "Petr <petrik.spac@gmail.com>",
    "Jiri Spac <capajj@gmail.com>"
  ],
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@11.8.0",
  "overrides": {
    "graphql": "^16.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "@types/react": "^19",
    "@types/react-dom": "^19"
  },
  "devDependencies": {
    "@apollo/client": "^4.2.3",
    "@chakra-ui/react": "2.10.4",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@graphql-codegen/cli": "^7.1.3",
    "@graphql-codegen/fragment-matcher": "^7.0.1",
    "@graphql-codegen/introspection": "^6.0.1",
    "@graphql-codegen/near-operation-file-preset": "^5.2.1",
    "@graphql-codegen/typescript": "^6.0.2",
    "@graphql-codegen/typescript-operations": "^6.0.4",
    "@graphql-codegen/typescript-react-apollo": "^4.4.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "framer-motion": "^12.40.0",
    "generate-password": "^1.7.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.55.0",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "zod": "^4.4.3",
    "zx": "^8.8.5"
  },
  "scripts": {
    "dev:be": "cd backend && pnpm run dev",
    "dev:be:local": "cd backend && pnpm run local",
    "dev:ex": "cd web-extension && pnpm run dev",
    "dev:vault-fe": "cd vault-web && pnpm run dev",
    "dev:vault": "turbo run local --filter=authier-backend --filter=authier-vault-web",
    "dev": "turbo run dev --filter=authier-backend --filter=authier-web-extension",
    "tsc": "turbo run tsc",
    "bump": "npm-run-all --parallel bump:*",
    "bump:be": "cd backend && ncu -u",
    "bump:ex": "cd web-extension && ncu -u",
    "bump:w": "ncu -u",
    "test": "cd backend && pnpm test && cd .. && cd web-extension && pnpm test && cd .. && cd vault-web && pnpm test",
    "gfs": "graphql-codegen --config codegen.yml",
    "gbs": "cd backend && pnpm gbs",
    "schemas": "pnpm gbs && pnpm gfs",
    "preinstall": "npx only-allow pnpm",
    "release": "cd web-extension && pnpm run release",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  }
}
